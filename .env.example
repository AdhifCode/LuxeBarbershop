# ──────────────────────────────────────────────
# Luxe Barbershop · Environment Variables
# ──────────────────────────────────────────────

# Public Supabase project URL (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Public anon key (RLS protects everything)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only service role key (bypasses RLS — NEVER expose)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL — used for auth redirects and metadata
NEXT_PUBLIC_SITE_URL=http://localhost:3000
